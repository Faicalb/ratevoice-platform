  loadSpeed       Float? // seconds
  mobileFriendly  Boolean  @default(true)
  issues          Json? // Detailed list of issues
  crawledAt       DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model GlobalSeoSettings {
  id                 String   @id @default(uuid())
  defaultTitle       String   @default("RateVoice - Review Platform")
  defaultDescription String   @default("Best reviews for hotels and restaurants.")
  globalKeywords     String   @default("reviews, hotels, restaurants")
  canonicalDomain    String   @default("https://ratevoice.com")
  robotsTxt          String   @default("User-agent: *\nAllow: /")
  updatedAt          DateTime @updatedAt
}

model SeoLandingPage {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  keywords    String
  city        String?
  category    String?
  content     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SeoKeyword {
  id         String   @id @default(uuid())
  keyword    String   @unique
  volume     Int      @default(0)
  difficulty Int      @default(0)
  category   String?
  updatedAt  DateTime @updatedAt
}
