model MarketSignal {
  id          String   @id @default(uuid())
  source      String // NEWS, SOCIAL, COMPETITOR
  signalType  String // TREND, EVENT
  description String
  impactScore Float
  detectedAt  DateTime @default(now())
}

// -----------------------------------------------------------------------------
// SYSTEM & CONFIG
// -----------------------------------------------------------------------------

model SEOPage {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String?
  keywords    String[]
  content     String?
  updatedAt   DateTime @updatedAt
}

model SeoHistory {
  id         String   @id @default(uuid())
  businessId String
  action     String // UPDATE, APPROVE, REJECT, LOCK, UNLOCK
  oldValue   Json?
  newValue   Json?
  editedBy   String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}

model APIKey {
  id         String    @id @default(uuid())
  userId     String?
  businessId String?
  key        String    @unique
  scopes     String[]
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  user     User?     @relation(fields: [userId], references: [id])
  business Business? @relation(fields: [businessId], references: [id])
}

model ExternalIntegration {
  id         String   @id @default(uuid())
  businessId String
  provider   String // GOOGLE, FACEBOOK, STRIPE
  apiKey     String?
  config     Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}

model ChannelIntegration {
  id                   String    @id @default(uuid())
  businessId           String
  name                 String // Booking.com, Airbnb
  type                 String // OTA, PMS
  status               String // CONNECTED, SYNCING, ERROR, DISCONNECTED
  lastSync             DateTime?
  config               Json? // Credentials, mapping
  importedReservations Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model ICalIntegration {
  id          String    @id @default(uuid())
  businessId  String
  name        String
  url         String
  frequency   String    @default("1hour")
  status      String // ACTIVE, ERROR, PAUSED
  lastSync    DateTime?
  totalEvents Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model SyncLog {
  id            String   @id @default(uuid())
  businessId    String
  integrationId String? // Optional link to Channel or ICal
  platform      String
  status        String // SUCCESS, FAILED, WARNING
  imported      Int      @default(0)
  errors        Int      @default(0)
  latency       Int      @default(0)
  timestamp     DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId, timestamp])
}

model TrafficLog {
  id         String   @id @default(uuid())
  path       String
  method     String
  statusCode Int
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  @@index([timestamp])
}

model UsageStatistic {
  id         String   @id @default(uuid())
  metric     String // API_CALLS, STORAGE
  value      Float
  recordedAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  resource  String
  details   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SecurityEvent {
  id        String   @id @default(uuid())
  userId    String?
  eventType String // FAILED_LOGIN, SUSPICIOUS_ACTIVITY
  ipAddress String?
  details   String?
  severity  String // LOW, MEDIUM, HIGH, CRITICAL
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model FeatureFlag {
  id                String  @id @default(uuid())
  key               String  @unique
  isEnabled         Boolean @default(false)
  description       String?
  rolloutPercentage Int     @default(0)
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String // STRING, BOOLEAN, NUMBER, JSON
  updatedAt DateTime @updatedAt
}

