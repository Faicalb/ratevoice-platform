model KeywordRanking {
  id           String   @id @default(uuid())
  businessId   String
  keyword      String
  position     Int
  searchEngine String   @default("google") // google, bing
  change       Int      @default(0) // position change
  url          String?
  volume       Int      @default(0)
  difficulty   Int      @default(0)
  createdAt    DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model Backlink {
  id             String   @id @default(uuid())
  businessId     String
  url            String
  authorityScore Int
  anchorText     String?
  targetUrl      String?
  isDoFollow     Boolean  @default(true)
  firstSeen      DateTime @default(now())
  lastSeen       DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model SeoAudit {
  id              String   @id @default(uuid())
  businessId      String
  score           Int      @default(0)
  missingMeta     Boolean  @default(false)
  missingSchema   Boolean  @default(false)
  brokenCanonical Boolean  @default(false)
