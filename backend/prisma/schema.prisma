// -----------------------------------------------------------------------------

model AIInsight {
  id         String   @id @default(uuid())
  category   String // MARKET, REVENUE, CUSTOMER
  content    String
  confidence Float
  createdAt  DateTime @default(now())
}

model AIMarketReport {
  id        String   @id @default(uuid())
  region    String
  period    String
  data      Json // Flexible data structure for report
  createdAt DateTime @default(now())
}

model AIBookingForecast {
  id             String   @id @default(uuid())
  targetDate     DateTime
  predictedCount Int
  confidence     Float
  createdAt      DateTime @default(now())
}

model Competitor {
  id           String   @id @default(uuid())
  businessId   String
  name         String
  website      String?
  industry     String?
  marketShare  Decimal?
  rating       Decimal?
  isVisible    Boolean  @default(true)
  lastAnalysis DateTime?
  trackedSince DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}

model SeoHealth {
  id             String   @id @default(uuid())
  businessId     String   @unique
  indexed        Boolean  @default(false)
  metaErrors     String[]
  missingSchema  Boolean  @default(false)
  duplicateTitle Boolean  @default(false)
  lastScan       DateTime @default(now())

