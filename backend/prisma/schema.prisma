// LOCALIZATION
// -----------------------------------------------------------------------------

model Language {
  id       String  @id @default(uuid())
  code     String  @unique // en, ar, fr, etc.
  name     String
  isRTL    Boolean @default(false)
  isActive Boolean @default(true)
}

model BusinessTranslation {
  id           String  @id @default(uuid())
  businessId   String
  languageCode String
  name         String?
  description  String?

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, languageCode])
}

model AppTranslation {
  id           String @id @default(uuid())
  key          String
  languageCode String
  value        String

  @@unique([key, languageCode])
}

model AIResponseTranslation {
  id             String   @id @default(uuid())
  originalText   String
  translatedText String
  sourceLang     String
  targetLang     String
  createdAt      DateTime @default(now())
}

// -----------------------------------------------------------------------------
// API GATEWAY & PROVIDERS
// -----------------------------------------------------------------------------

model ExternalProvider {
  id           String   @id @default(uuid())
  serviceName  String // AI, SMS, EMAIL, MAPS, SPEECH_TO_TEXT, PAYMENTS, TRANSLATION
  providerName String // Gemini, OpenAI, Claude, Twilio, SendGrid
  apiKey       String // Encrypted
  apiSecret    String? // Encrypted, Optional
  endpoint     String?
  priority     Int      @default(1)
  rateLimit    Int      @default(60) // Requests per minute
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE, ERROR
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  usage              ProviderUsage[]
  metrics            ApiMetric[]
  fallbackProvider   ExternalProvider?  @relation("ProviderFallback", fields: [fallbackProviderId], references: [id])
  fallbackProviderId String?
  fallbackFor        ExternalProvider[] @relation("ProviderFallback")

  // Health & Metrics
  healthStatus    String    @default("HEALTHY") // HEALTHY, DEGRADED, FAILING
  lastHealthCheck DateTime?
  currentLatency  Float     @default(0) // ms (real-time)
  failureCount    Int       @default(0)
  costPerUnit     Float     @default(0) // Cost per 1k tokens or request
}

model ProviderUsage {
  id           String    @id @default(uuid())
  providerId   String
  serviceName  String
  requestCount Int       @default(0)
  errorCount   Int       @default(0)
  avgLatency   Float     @default(0) // ms
  periodStart  DateTime  @default(now()) // For time-series aggregation (hourly/daily)
  periodEnd    DateTime?

  provider ExternalProvider @relation(fields: [providerId], references: [id])

  @@index([providerId, periodStart])
}

model ApiMetric {
  id         String   @id @default(uuid())
  providerId String
  timestamp  DateTime @default(now())
  latency    Float
  success    Boolean
  statusCode Int?

  provider ExternalProvider @relation(fields: [providerId], references: [id])

  @@index([providerId, timestamp])
}

