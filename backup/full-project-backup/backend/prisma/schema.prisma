// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// CORE & AUTHENTICATION
// -----------------------------------------------------------------------------

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  passwordHash    String?
  fullName        String?
  avatarUrl       String?
  phoneNumber     String?
  isVerified      Boolean          @default(false)
  isActive        Boolean          @default(true)
  mustChangePassword Boolean       @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  // Relations
  roles           UserRole[]
  businesses      Business[]       @relation("OwnerBusiness")
  reviews         VoiceReview[]
  textReviews     TextReview[]
  bookings        Booking[]
  wallet          Wallet?
  conversations   ConversationParticipant[]
  messages        Message[]
  notifications   Notification[]
  preferences     NotificationPreference?
  ambassadorProfile Ambassador?
  loginSessions   LoginSession[]
  auditLogs       AuditLog[]
  securityEvents  SecurityEvent[]
  apiKeys         APIKey[]
  storyReactions  StoryReaction[]
  liveStreamViewers LiveStreamViewer[]
  
  @@index([email])
  @@index([phoneNumber])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique // ADMIN, BUSINESS, USER, AMBASSADOR, ELITE
  description String?
  
  // Relations
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  action      String           @unique // e.g., "create:business", "read:analytics"
  description String?
  
  // Relations
  roles       RolePermission[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  branchId  String?
  assignedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  branch    BusinessBranch? @relation(fields: [branchId], references: [id])

  @@unique([userId, roleId, branchId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model LoginSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  isValid   Boolean  @default(true)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

// -----------------------------------------------------------------------------
// BUSINESS & LISTINGS
// -----------------------------------------------------------------------------

model Business {
  id              String   @id @default(uuid())
  ownerId         String
  name            String
  description     String?
  logoUrl         String?
  website         String?
  category        String?
  status          String   @default("PENDING") // PENDING, ACTIVE, SUSPENDED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  owner           User     @relation("OwnerBusiness", fields: [ownerId], references: [id])
  
  branches        BusinessBranch[]
  verifications   BusinessVerification[]
  adCampaigns     AdCampaign[]
  competitors     Competitor[]
  apiKeys         APIKey[]
  externalIntegrations ExternalIntegration[]
  translations    BusinessTranslation[]
  
  @@index([ownerId])
  @@index([category])
}

model BusinessBranch {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  address     String?
  city        String?
  country     String?
  latitude    Float?
  longitude   Float?
  phoneNumber String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  voiceReviews VoiceReview[]
  textReviews  TextReview[]
  bookings     Booking[]
  stories      Story[]
  liveStreams  LiveStream[]
  staff        UserRole[] // Can be extended for branch-specific roles if needed
  
  @@index([businessId])
  @@index([city, country])
}

model BusinessVerification {
  id          String   @id @default(uuid())
  businessId  String
  documentUrl String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  verifiedAt  DateTime?
  rejectionReason String?
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// REVIEWS & AI ANALYSIS
// -----------------------------------------------------------------------------

model VoiceReview {
  id          String   @id @default(uuid())
  userId      String
  branchId    String
  audioUrl    String
  transcript  String?
  rating      Int
  sentiment   String?  // POSITIVE, NEUTRAL, NEGATIVE
  status      String   @default("PUBLISHED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  branch      BusinessBranch @relation(fields: [branchId], references: [id])
  
  replies     ReviewReply[]
  aiAnalysis  AIReviewAnalysis?
  
  @@index([userId])
  @@index([branchId])
}

model TextReview {
  id          String   @id @default(uuid())
  userId      String
  branchId    String
  content     String
  rating      Int
  sentiment   String?
  status      String   @default("PUBLISHED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  branch      BusinessBranch @relation(fields: [branchId], references: [id])
  
  replies     ReviewReply[]
  aiAnalysis  AIReviewAnalysis? // Reusing same AI analysis model or create separate
  
  @@index([userId])
  @@index([branchId])
}

model ReviewReply {
  id            String   @id @default(uuid())
  voiceReviewId String?
  textReviewId  String?
  responderId   String // Could be business owner or staff
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  voiceReview   VoiceReview? @relation(fields: [voiceReviewId], references: [id])
  textReview    TextReview?  @relation(fields: [textReviewId], references: [id])
}

model AIReviewAnalysis {
  id            String   @id @default(uuid())
  voiceReviewId String? @unique
  textReviewId  String? @unique
  sentimentScore Float
  keywords      String[] // Stored as array
  summary       String?
  topics        String[]
  createdAt     DateTime @default(now())

  voiceReview   VoiceReview? @relation(fields: [voiceReviewId], references: [id])
  textReview    TextReview?  @relation(fields: [textReviewId], references: [id])
}

// -----------------------------------------------------------------------------
// BOOKINGS & PAYMENTS
// -----------------------------------------------------------------------------

model Booking {
  id          String   @id @default(uuid())
  userId      String
  branchId    String
  bookingDate DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  status      String   @default("PENDING") // CONFIRMED, CANCELLED, COMPLETED
  totalAmount Decimal
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  branch      BusinessBranch @relation(fields: [branchId], references: [id])
  
  payment     BookingPayment?
  
  @@index([userId])
  @@index([branchId])
  @@index([bookingDate])
}

model BookingPayment {
  id            String   @id @default(uuid())
  bookingId     String   @unique
  amount        Decimal
  currency      String
  paymentMethod String   // STRIPE, PAYPAL, WALLET
  transactionId String?
  status        String   @default("PENDING") // SUCCESS, FAILED
  createdAt     DateTime @default(now())

  booking       Booking  @relation(fields: [bookingId], references: [id])
}

// -----------------------------------------------------------------------------
// WALLET & LOYALTY
// -----------------------------------------------------------------------------

model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  balance     Decimal  @default(0)
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(uuid())
  walletId    String
  amount      Decimal
  type        String   // DEPOSIT, WITHDRAWAL, PAYMENT, REWARD
  referenceId String?  // ID of related entity (booking, ad, etc.)
  status      String   @default("COMPLETED")
  createdAt   DateTime @default(now())

  wallet      Wallet   @relation(fields: [walletId], references: [id])
}

model PointsLedger {
  id          String   @id @default(uuid())
  userId      String
  points      Int
  reason      String   // REVIEW_REWARD, BOOKING_BONUS
  createdAt   DateTime @default(now())
  
  // No direct relation to User for simplicity in massive ledger, but ideally linked
}

model PointsRule {
  id          String   @id @default(uuid())
  action      String   @unique // WRITE_REVIEW, BOOKING
  points      Int
  isActive    Boolean  @default(true)
}

// -----------------------------------------------------------------------------
// ADS & MARKETING
// -----------------------------------------------------------------------------

model AdCampaign {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  budget      Decimal
  startDate   DateTime
  endDate     DateTime
  status      String   @default("DRAFT") // ACTIVE, PAUSED, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id])
  ads         Ad[]
}

model Ad {
  id          String   @id @default(uuid())
  campaignId  String
  title       String
  content     String?
  imageUrl    String?
  targetUrl   String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  campaign    AdCampaign @relation(fields: [campaignId], references: [id])
  clicks      AdClick[]
  analytics   AdAnalytics[]
}

model AdClick {
  id          String   @id @default(uuid())
  adId        String
  userId      String?
  ipAddress   String?
  clickedAt   DateTime @default(now())

  ad          Ad       @relation(fields: [adId], references: [id])
}

model AdAnalytics {
  id          String   @id @default(uuid())
  adId        String
  date        DateTime @default(now()) // daily stats
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Decimal  @default(0)

  ad          Ad       @relation(fields: [adId], references: [id])
  
  @@unique([adId, date])
}

// -----------------------------------------------------------------------------
// STORIES & LIVE STREAMING
// -----------------------------------------------------------------------------

model Story {
  id          String   @id @default(uuid())
  branchId    String
  mediaUrl    String
  type        String   // IMAGE, VIDEO
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  branch      BusinessBranch @relation(fields: [branchId], references: [id])
  views       StoryView[]
  reactions   StoryReaction[]
}

model StoryView {
  id          String   @id @default(uuid())
  storyId     String
  viewerId    String? // Nullable if anonymous
  viewedAt    DateTime @default(now())

  story       Story    @relation(fields: [storyId], references: [id])
}

model StoryReaction {
  id          String   @id @default(uuid())
  storyId     String
  userId      String
  reaction    String   // LIKE, LOVE, FIRE
  createdAt   DateTime @default(now())

  story       Story    @relation(fields: [storyId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model LiveStream {
  id          String   @id @default(uuid())
  branchId    String
  title       String
  streamKey   String?
  status      String   @default("SCHEDULED") // LIVE, ENDED
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime @default(now())

  branch      BusinessBranch @relation(fields: [branchId], references: [id])
  viewers     LiveStreamViewer[]
}

model LiveStreamViewer {
  id          String   @id @default(uuid())
  streamId    String
  userId      String
  joinedAt    DateTime @default(now())
  leftAt      DateTime?

  stream      LiveStream @relation(fields: [streamId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
}

// -----------------------------------------------------------------------------
// MESSAGING & NOTIFICATIONS
// -----------------------------------------------------------------------------

model Conversation {
  id          String   @id @default(uuid())
  type        String   @default("DIRECT") // DIRECT, GROUP, SUPPORT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String?
  createdAt      DateTime @default(now())
  readAt         DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
  attachments    MessageAttachment[]
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  body        String
  type        String   // SYSTEM, BOOKING, REVIEW
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  email       Boolean  @default(true)
  push        Boolean  @default(true)
  sms         Boolean  @default(false)

  user        User     @relation(fields: [userId], references: [id])
}

// -----------------------------------------------------------------------------
// AMBASSADOR & ELITE
// -----------------------------------------------------------------------------

model Ambassador {
  id          String   @id @default(uuid())
  userId      String   @unique
  referralCode String  @unique
  commissionRate Float @default(0.05)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  services    AmbassadorService[]
}

model AmbassadorService {
  id           String   @id @default(uuid())
  ambassadorId String
  name         String
  description  String?
  price        Decimal
  createdAt    DateTime @default(now())

  ambassador   Ambassador @relation(fields: [ambassadorId], references: [id])
  orders       ServiceOrder[]
}

model ServiceOrder {
  id          String   @id @default(uuid())
  serviceId   String
  buyerId     String // Could link to User or Business
  status      String   @default("PENDING")
  amount      Decimal
  createdAt   DateTime @default(now())

  service     AmbassadorService @relation(fields: [serviceId], references: [id])
}

model EliteLevel {
  id          String   @id @default(uuid())
  name        String   // SILVER, GOLD, PLATINUM
  minPoints   Int
  benefits    String[]
}

// -----------------------------------------------------------------------------
// AI INTELLIGENCE & MARKET
// -----------------------------------------------------------------------------

model AIInsight {
  id          String   @id @default(uuid())
  category    String   // MARKET, REVENUE, CUSTOMER
  content     String
  confidence  Float
  createdAt   DateTime @default(now())
}

model AIMarketReport {
  id          String   @id @default(uuid())
  region      String
  period      String
  data        Json     // Flexible data structure for report
  createdAt   DateTime @default(now())
}

model AIBookingForecast {
  id          String   @id @default(uuid())
  targetDate  DateTime
  predictedCount Int
  confidence  Float
  createdAt   DateTime @default(now())
}

model Competitor {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  website     String?
  trackedSince DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id])
}

model MarketSignal {
  id          String   @id @default(uuid())
  source      String   // NEWS, SOCIAL, COMPETITOR
  signalType  String   // TREND, EVENT
  description String
  impactScore Float
  detectedAt  DateTime @default(now())
}

// -----------------------------------------------------------------------------
// SYSTEM & CONFIG
// -----------------------------------------------------------------------------

model SEOPage {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String?
  keywords    String[]
  content     String?
  updatedAt   DateTime @updatedAt
}

model APIKey {
  id          String   @id @default(uuid())
  userId      String?
  businessId  String?
  key         String   @unique
  scopes      String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  user        User?     @relation(fields: [userId], references: [id])
  business    Business? @relation(fields: [businessId], references: [id])
}

model ExternalIntegration {
  id          String   @id @default(uuid())
  businessId  String
  provider    String   // GOOGLE, FACEBOOK, STRIPE
  apiKey      String?
  config      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id])
}

model TrafficLog {
  id          String   @id @default(uuid())
  path        String
  method      String
  statusCode  Int
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())
}

model UsageStatistic {
  id          String   @id @default(uuid())
  metric      String   // API_CALLS, STORAGE
  value       Float
  recordedAt  DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  resource    String
  details     Json?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model SecurityEvent {
  id          String   @id @default(uuid())
  userId      String?
  eventType   String   // FAILED_LOGIN, SUSPICIOUS_ACTIVITY
  ipAddress   String?
  details     String?
  severity    String   // LOW, MEDIUM, HIGH, CRITICAL
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  isEnabled   Boolean  @default(false)
  description String?
  rolloutPercentage Int @default(0)
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  type        String   // STRING, BOOLEAN, NUMBER, JSON
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// LOCALIZATION
// -----------------------------------------------------------------------------

model Language {
  id          String   @id @default(uuid())
  code        String   @unique // en, ar, fr, etc.
  name        String
  isRTL       Boolean  @default(false)
  isActive    Boolean  @default(true)
}

model BusinessTranslation {
  id          String   @id @default(uuid())
  businessId  String
  languageCode String
  name        String?
  description String?
  
  business    Business @relation(fields: [businessId], references: [id])
  
  @@unique([businessId, languageCode])
}

model AppTranslation {
  id          String   @id @default(uuid())
  key         String
  languageCode String
  value       String
  
  @@unique([key, languageCode])
}

model AIResponseTranslation {
  id          String   @id @default(uuid())
  originalText String
  translatedText String
  sourceLang  String
  targetLang  String
  createdAt   DateTime @default(now())
}
